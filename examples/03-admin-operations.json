[
  {
    "id": "tab-admin-ops",
    "type": "tab",
    "label": "Admin — operations",
    "disabled": false,
    "info": "One admin node, many actions. Fire the injects top-to-bottom for the happy path, or pick the 'unknown action' inject to see the catch-node error path."
  },
  {
    "id": "broker-admin",
    "type": "kafka-suite-broker",
    "name": "Local Kafka",
    "brokers": "localhost:9092",
    "clientId": "nr-example-admin",
    "backend": "kafkajs",
    "servicePreset": "self-hosted",
    "authType": "none",
    "logLevel": "warn",
    "connectionTimeout": 3000,
    "requestTimeout": 30000,
    "maxRetryTime": 30000,
    "initialRetryTime": 300,
    "retries": 5,
    "sslRejectUnauthorized": true
  },
  {
    "id": "ao-comment",
    "type": "comment",
    "z": "tab-admin-ops",
    "name": "Admin operations — fire injects in order",
    "info": "",
    "x": 220,
    "y": 40,
    "wires": []
  },
  {
    "id": "ao-create",
    "type": "inject",
    "z": "tab-admin-ops",
    "name": "1. createTopic demo-admin (3p)",
    "props": [
      { "p": "action", "v": "createTopic", "vt": "str" },
      { "p": "topic", "v": "demo-admin", "vt": "str" },
      { "p": "config", "v": "{\"partitions\":3,\"replicationFactor\":1}", "vt": "json" }
    ],
    "repeat": "",
    "crontab": "",
    "once": false,
    "onceDelay": 0.1,
    "topic": "",
    "x": 220,
    "y": 100,
    "wires": [["ao-admin"]]
  },
  {
    "id": "ao-list",
    "type": "inject",
    "z": "tab-admin-ops",
    "name": "2. listTopics",
    "props": [ { "p": "action", "v": "listTopics", "vt": "str" } ],
    "repeat": "",
    "crontab": "",
    "once": false,
    "onceDelay": 0.1,
    "topic": "",
    "x": 170,
    "y": 160,
    "wires": [["ao-admin"]]
  },
  {
    "id": "ao-describe",
    "type": "inject",
    "z": "tab-admin-ops",
    "name": "3. describeCluster",
    "props": [ { "p": "action", "v": "describeCluster", "vt": "str" } ],
    "repeat": "",
    "crontab": "",
    "once": false,
    "onceDelay": 0.1,
    "topic": "",
    "x": 180,
    "y": 210,
    "wires": [["ao-admin"]]
  },
  {
    "id": "ao-offsets",
    "type": "inject",
    "z": "tab-admin-ops",
    "name": "4. fetchTopicOffsets demo-admin",
    "props": [
      { "p": "action", "v": "fetchTopicOffsets", "vt": "str" },
      { "p": "topic", "v": "demo-admin", "vt": "str" }
    ],
    "repeat": "",
    "crontab": "",
    "once": false,
    "onceDelay": 0.1,
    "topic": "",
    "x": 220,
    "y": 260,
    "wires": [["ao-admin"]]
  },
  {
    "id": "ao-delete",
    "type": "inject",
    "z": "tab-admin-ops",
    "name": "5. deleteTopic demo-admin",
    "props": [
      { "p": "action", "v": "deleteTopic", "vt": "str" },
      { "p": "topic", "v": "demo-admin", "vt": "str" }
    ],
    "repeat": "",
    "crontab": "",
    "once": false,
    "onceDelay": 0.1,
    "topic": "",
    "x": 200,
    "y": 310,
    "wires": [["ao-admin"]]
  },
  {
    "id": "ao-bad",
    "type": "inject",
    "z": "tab-admin-ops",
    "name": "✗ Unknown action (→ catch)",
    "props": [ { "p": "action", "v": "doMagic", "vt": "str" } ],
    "repeat": "",
    "crontab": "",
    "once": false,
    "onceDelay": 0.1,
    "topic": "",
    "x": 210,
    "y": 370,
    "wires": [["ao-admin"]]
  },
  {
    "id": "ao-admin",
    "type": "kafka-suite-admin",
    "z": "tab-admin-ops",
    "name": "Admin",
    "broker": "broker-admin",
    "x": 530,
    "y": 220,
    "wires": [["ao-debug"]]
  },
  {
    "id": "ao-debug",
    "type": "debug",
    "z": "tab-admin-ops",
    "name": "Admin result",
    "active": true,
    "tosidebar": true,
    "console": true,
    "tostatus": true,
    "complete": "true",
    "targetType": "full",
    "statusVal": "action",
    "statusType": "msg",
    "x": 720,
    "y": 220,
    "wires": []
  },
  {
    "id": "ao-catch",
    "type": "catch",
    "z": "tab-admin-ops",
    "name": "Catch admin errors",
    "scope": ["ao-admin"],
    "uncaught": false,
    "x": 220,
    "y": 460,
    "wires": [["ao-debug-err"]]
  },
  {
    "id": "ao-debug-err",
    "type": "debug",
    "z": "tab-admin-ops",
    "name": "Caught error",
    "active": true,
    "tosidebar": true,
    "console": true,
    "tostatus": true,
    "complete": "error",
    "targetType": "msg",
    "statusVal": "error.message",
    "statusType": "msg",
    "x": 500,
    "y": 460,
    "wires": []
  }
]
