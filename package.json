{
  "name": "node-red-contrib-kafka-suite",
  "version": "0.0.1",
  "description": "BETA — A comprehensive Kafka integration for Node-RED with producer, consumer, admin, and Schema Registry nodes. Dual backends (kafkajs / @confluentinc/kafka-javascript) and presets for Confluent Cloud, AWS MSK, Azure Event Hubs, Aiven, and Redpanda. Please file issues at https://github.com/blanpa/node-red-contrib-kafka-suite/issues.",
  "keywords": [
    "node-red",
    "kafka",
    "apache-kafka",
    "confluent",
    "producer",
    "consumer",
    "schema-registry",
    "avro",
    "streaming",
    "iot"
  ],
  "author": "blanpa",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/blanpa/node-red-contrib-kafka-suite.git"
  },
  "homepage": "https://github.com/blanpa/node-red-contrib-kafka-suite#readme",
  "bugs": {
    "url": "https://github.com/blanpa/node-red-contrib-kafka-suite/issues"
  },
  "files": [
    "lib/",
    "nodes/",
    "examples/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=16.0.0"
  },
  "node-red": {
    "version": ">=3.0.0",
    "nodes": {
      "kafka-suite-broker": "nodes/kafka-suite-broker.js",
      "kafka-suite-producer": "nodes/kafka-suite-producer.js",
      "kafka-suite-consumer": "nodes/kafka-suite-consumer.js",
      "kafka-suite-admin": "nodes/kafka-suite-admin.js",
      "kafka-suite-schema-registry": "nodes/kafka-suite-schema-registry.js"
    }
  },
  "dependencies": {
    "kafkajs": "^2.2.4"
  },
  "optionalDependencies": {
    "@kafkajs/confluent-schema-registry": "^3.3.0"
  },
  "peerDependencies": {
    "@confluentinc/kafka-javascript": "^1.9.0"
  },
  "peerDependenciesMeta": {
    "@confluentinc/kafka-javascript": {
      "optional": true
    }
  },
  "devDependencies": {
    "mocha": "^10.7.0",
    "node-red": "^4.0.0",
    "node-red-node-test-helper": "^0.3.4",
    "should": "^13.2.3",
    "sinon": "^17.0.0"
  },
  "scripts": {
    "test": "mocha \"test/**/*_spec.js\" --recursive --exit --timeout 10000",
    "test:integration": "node test/integration/docker-test.js"
  }
}
